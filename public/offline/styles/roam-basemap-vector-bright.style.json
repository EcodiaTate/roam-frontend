{
  "version": 8,
  "name": "Roam Outback Bright",
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "pmtiles://https://vzauarlfmkjfkcphojbd.supabase.co/storage/v1/object/public/tiles/australia.pmtiles",
      "attribution": "\u00a9 OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": { "background-color": "#e8dfd0" }
    },

    {
      "id": "ocean",
      "type": "fill",
      "source": "basemap",
      "source-layer": "ocean",
      "paint": {
        "fill-color": [
          "interpolate", ["linear"], ["zoom"],
          0, "#9ac5d9",
          5, "#7db8d0",
          10, "#6aafc9"
        ]
      }
    },

    {
      "id": "land",
      "type": "fill",
      "source": "basemap",
      "source-layer": "land",
      "paint": {
        "fill-color": [
          "match", ["get", "kind"],
          "forest",           "#9abf96",
          "wood",             "#90b68c",
          "scrub",            "#b2c49c",
          "heath",            "#b8c8a2",
          "grass",            "#c4d8aa",
          "grassland",        "#c0d4a5",
          "meadow",           "#ccdeb4",
          "park",             "#b4d4a0",
          "national_park",    "#a8ce96",
          "nature_reserve",   "#a8ce96",
          "protected_area",   "#acd09a",
          "farmland",         "#dbd6a6",
          "orchard",          "#c8d4a0",
          "vineyard",         "#c8d4a0",
          "wetland",          "#9ec8bc",
          "marsh",            "#9ec8bc",
          "bog",              "#a0c4b4",
          "beach",            "#f0debb",
          "sand",             "#eddbB5",
          "desert",           "#e0c58c",
          "bare_rock",        "#d5cbb5",
          "scree",            "#d0c8b2",
          "shingle",          "#d2cab4",
          "glacier",          "#d8eef0",
          "quarry",           "#ccc4b0",
          "residential",      "#e2dace",
          "retail",           "#e0d4c6",
          "#ddd2be"
        ],
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.7,
          8, 0.85,
          12, 0.92
        ]
      }
    },

    {
      "id": "land-park-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "land",
      "filter": ["in", "kind", "park", "national_park", "nature_reserve", "protected_area"],
      "paint": {
        "line-color": "#7aab6a",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.15, 8, 0.3, 12, 0.45],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.4, 8, 0.8, 12, 1.2]
      }
    },

    {
      "id": "water-polygons",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water_polygons",
      "paint": {
        "fill-color": [
          "interpolate", ["linear"], ["zoom"],
          4, "#6aadbe",
          10, "#5ea4b8",
          14, "#539bb2"
        ],
        "fill-opacity": 0.92
      }
    },

    {
      "id": "water-lines",
      "type": "line",
      "source": "basemap",
      "source-layer": "water_lines",
      "paint": {
        "line-color": "#4a98ad",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.3, 8, 0.5, 12, 0.7, 14, 0.85],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, ["match", ["get", "kind"], "river", 1.0, 0.4],
          8, ["match", ["get", "kind"], "river", 2.0, 1.0],
          12, ["match", ["get", "kind"], "river", 3.0, 1.8],
          14, ["match", ["get", "kind"], "river", 4.0, 2.5]
        ]
      }
    },

    {
      "id": "water-lines-labels",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "water_lines_labels",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 9, 14, 11],
        "text-font": ["Open Sans Italic", "Arial Unicode MS Regular"],
        "text-max-angle": 25
      },
      "paint": {
        "text-color": "#3a7a8a",
        "text-halo-color": "rgba(232, 223, 208, 0.7)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0.5
      }
    },

    {
      "id": "water-polygons-labels",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "water_polygons_labels",
      "minzoom": 10,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 9, 14, 12],
        "text-font": ["Open Sans Italic", "Arial Unicode MS Regular"],
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#3a7a8a",
        "text-halo-color": "rgba(232, 223, 208, 0.6)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0.5
      }
    },

    {
      "id": "dam-lines",
      "type": "line",
      "source": "basemap",
      "source-layer": "dam_lines",
      "minzoom": 12,
      "paint": {
        "line-color": "#8aaa9a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.0, 14, 2.0],
        "line-opacity": 0.6
      }
    },

    {
      "id": "boundaries",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "paint": {
        "line-color": [
          "match", ["get", "admin_level"],
          2, "rgba(120, 90, 60, 0.45)",
          4, "rgba(120, 90, 60, 0.3)",
          "rgba(120, 90, 60, 0.15)"
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, ["match", ["get", "admin_level"], 2, 1.0, 4, 0.6, 0.3],
          6, ["match", ["get", "admin_level"], 2, 1.6, 4, 1.0, 0.5],
          10, ["match", ["get", "admin_level"], 2, 2.0, 4, 1.4, 0.7]
        ],
        "line-dasharray": [4, 3]
      }
    },

    {
      "id": "boundary-labels",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "boundary_labels",
      "filter": ["<=", "admin_level", 4],
      "minzoom": 3,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 6, 13],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-letter-spacing": 0.15,
        "text-transform": "uppercase",
        "text-max-width": 8
      },
      "paint": {
        "text-color": "rgba(120, 90, 60, 0.45)",
        "text-halo-color": "rgba(232, 223, 208, 0.6)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0.8
      }
    },

    {
      "id": "buildings",
      "type": "fill",
      "source": "basemap",
      "source-layer": "buildings",
      "minzoom": 14,
      "paint": {
        "fill-color": "#c8baa0",
        "fill-opacity": 0.6,
        "fill-outline-color": "rgba(160, 140, 110, 0.5)"
      }
    },

    {
      "id": "pier-lines",
      "type": "line",
      "source": "basemap",
      "source-layer": "pier_lines",
      "minzoom": 12,
      "paint": {
        "line-color": "#c0b8a4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 14, 3.0],
        "line-opacity": 0.7
      }
    },

    {
      "id": "bridges",
      "type": "line",
      "source": "basemap",
      "source-layer": "bridges",
      "minzoom": 12,
      "paint": {
        "line-color": "#b8b0a0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 2.0, 14, 4.0],
        "line-opacity": 0.5
      }
    },

    {
      "id": "ferries",
      "type": "line",
      "source": "basemap",
      "source-layer": "ferries",
      "paint": {
        "line-color": "#4a8fa0",
        "line-opacity": 0.4,
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 10, 1.0, 14, 1.8],
        "line-dasharray": [3, 3]
      }
    },

    {
      "id": "streets-local-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["!in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary"],
      "minzoom": 12,
      "paint": {
        "line-color": "rgba(140, 120, 95, 0.3)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 2.0, 14, 5.5]
      }
    },
    {
      "id": "streets-local",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["!in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary"],
      "minzoom": 12,
      "paint": {
        "line-color": "#f5ede0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.0, 14, 3.2],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 14, 0.8]
      }
    },

    {
      "id": "streets-tertiary-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "tertiary"],
      "minzoom": 9,
      "paint": {
        "line-color": "rgba(140, 120, 95, 0.3)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 2.2, 12, 5.0, 14, 8.0]
      }
    },
    {
      "id": "streets-tertiary",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "tertiary"],
      "minzoom": 9,
      "paint": {
        "line-color": "#f0e8d6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 1.0, 12, 2.8, 14, 5.0],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 9, 0.4, 11, 0.6, 14, 0.85]
      }
    },

    {
      "id": "streets-secondary-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "secondary"],
      "minzoom": 8,
      "paint": {
        "line-color": "rgba(140, 120, 90, 0.35)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 2.8, 12, 6.0, 14, 9.0]
      }
    },
    {
      "id": "streets-secondary",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "secondary"],
      "minzoom": 8,
      "paint": {
        "line-color": "#f0e6d2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.6, 12, 3.8, 14, 6.0],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 10, 0.7, 14, 0.9]
      }
    },

    {
      "id": "streets-primary-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "primary"],
      "minzoom": 6,
      "paint": {
        "line-color": "rgba(180, 140, 60, 0.35)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 2.4, 10, 5.5, 14, 11.0]
      }
    },
    {
      "id": "streets-primary",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "primary"],
      "minzoom": 6,
      "paint": {
        "line-color": "#f5dfa0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1.2, 10, 3.2, 14, 7.5],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0.55, 8, 0.75, 14, 1.0]
      }
    },

    {
      "id": "streets-trunk-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "trunk"],
      "minzoom": 5,
      "paint": {
        "line-color": "rgba(200, 120, 40, 0.4)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 2.2, 8, 4.5, 12, 8.0, 14, 12.0]
      }
    },
    {
      "id": "streets-trunk",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "trunk"],
      "minzoom": 5,
      "paint": {
        "line-color": "#f0c468",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1.0, 8, 2.8, 12, 5.5, 14, 8.5],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0.6, 8, 0.8, 14, 1.0]
      }
    },

    {
      "id": "streets-motorway-outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "motorway"],
      "minzoom": 4,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "rgba(180, 80, 40, 0.4)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 2.5, 8, 5.0, 12, 9.0, 14, 14.0]
      }
    },
    {
      "id": "streets-motorway",
      "type": "line",
      "source": "basemap",
      "source-layer": "streets",
      "filter": ["==", "kind", "motorway"],
      "minzoom": 4,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e8945a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 1.2, 8, 3.0, 12, 6.0, 14, 10.0]
      }
    },

    {
      "id": "public-transport",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "public_transport",
      "filter": ["==", "kind", "aerodrome"],
      "minzoom": 11,
      "layout": {
        "text-field": ["coalesce", ["get", "iata"], ""],
        "text-size": 10,
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-offset": [0, 0.8]
      },
      "paint": {
        "text-color": "rgba(100, 80, 60, 0.6)",
        "text-halo-color": "rgba(232, 223, 208, 0.6)",
        "text-halo-width": 0.8
      }
    },

    {
      "id": "place-labels-city",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "place_labels",
      "filter": ["in", "kind", "city", "capital", "state_capital", "state", "country"],
      "minzoom": 3,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          3, ["match", ["get", "kind"], "city", 13, "state_capital", 13, "capital", 13, 11],
          6, ["match", ["get", "kind"], "city", 18, "state_capital", 18, "capital", 18, 14],
          10, ["match", ["get", "kind"], "city", 22, "state_capital", 22, "capital", 22, 16]
        ],
        "text-font": ["Open Sans Bold", "Arial Unicode MS Regular"],
        "text-letter-spacing": 0.05,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#3a3228",
        "text-halo-color": "rgba(232, 223, 208, 0.9)",
        "text-halo-width": 1.8,
        "text-halo-blur": 0.4
      }
    },
    {
      "id": "place-labels-town",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "place_labels",
      "filter": ["==", "kind", "town"],
      "minzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 10, 14, 14, 17],
        "text-font": ["Open Sans Semibold", "Arial Unicode MS Regular"],
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#4a4038",
        "text-halo-color": "rgba(232, 223, 208, 0.85)",
        "text-halo-width": 1.5,
        "text-halo-blur": 0.4
      }
    },
    {
      "id": "place-labels-village",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "place_labels",
      "filter": ["in", "kind", "village", "hamlet", "suburb", "island", "locality", "isolated_dwelling", "neighbourhood"],
      "minzoom": 9,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 9, 12, 11, 14, 13],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-max-width": 6
      },
      "paint": {
        "text-color": "rgba(60, 52, 42, 0.8)",
        "text-halo-color": "rgba(232, 223, 208, 0.75)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0.5
      }
    },

    {
      "id": "street-labels",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "street_labels",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "coalesce",
          ["case", ["has", "ref"], ["concat", ["get", "ref"], " "], ""],
          ""
        ],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          10, ["match", ["get", "kind"], "motorway", 11, "trunk", 11, "primary", 10, 9],
          14, ["match", ["get", "kind"], "motorway", 14, "trunk", 14, "primary", 13, 11]
        ],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "rgba(60, 52, 42, 0.65)",
        "text-halo-color": "rgba(232, 223, 208, 0.8)",
        "text-halo-width": 1.2,
        "text-halo-blur": 0.4
      }
    },
    {
      "id": "street-labels-name",
      "type": "symbol",
      "source": "basemap",
      "source-layer": "street_labels",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"], ""],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 14, 12],
        "text-font": ["Open Sans Regular", "Arial Unicode MS Regular"],
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "rgba(60, 52, 42, 0.55)",
        "text-halo-color": "rgba(232, 223, 208, 0.75)",
        "text-halo-width": 1.0,
        "text-halo-blur": 0.5
      }
    }
  ]
}
